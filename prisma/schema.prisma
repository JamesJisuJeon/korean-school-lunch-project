// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  S_PA
  PA
  TEACHER
  TA
  PARENT
}

enum OrderType {
  PRE_ORDER
  ON_SITE
}

model User {
  id                 String    @id @default(cuid())
  email              String    @unique
  password           String
  name               String?
  phone              String?
  roles              Role[]    @default([PARENT])
  mustChangePassword Boolean   @default(true)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  students           Student[] @relation("StudentToParent")
  classesAsTeacher   Class[]   @relation("TeacherClasses")
  substitutes        Substitute[]
  assistantIn        ClassAssistant?
  posts              Post[]
}

model AcademicYear {
  id        String   @id @default(cuid())
  name      String   @unique // e.g., "2024-2025"
  startDate DateTime
  endDate   DateTime
  isActive  Boolean  @default(false)
  
  classes   Class[]
}

model Class {
  id             String       @id @default(cuid())
  name           String
  grade          String?      // e.g., "유치1", "초등2"
  teacherName    String?      // e.g., "홍길동"
  sortOrder      Int?         // 반 표시 순서
  academicYearId String
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])
  teacherId      String?      // Keep for linkage to User if needed later
  teacher        User?        @relation("TeacherClasses", fields: [teacherId], references: [id])

  students       Student[]
  substitutes    Substitute[]
  assistants     ClassAssistant[]
}

model ClassAssistant {
  id      String @id @default(cuid())
  classId String
  class   Class  @relation(fields: [classId], references: [id])
  userId  String @unique  // 1인은 최대 1개 학급에만 보조교사로 등록 가능
  user    User   @relation(fields: [userId], references: [id])
}

model Student {
  id           String       @id @default(cuid())
  name         String
  parents      User[]       @relation("StudentToParent")
  classId      String?
  class        Class?       @relation(fields: [classId], references: [id])
  isPAChild    Boolean      @default(false)
  isActive     Boolean      @default(true)

  orders       Order[]
  couponSales  CouponSale[]
}

model Substitute {
  id        String   @id @default(cuid())
  date      DateTime
  classId   String
  class     Class    @relation(fields: [classId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@unique([date, classId])
}

model Menu {
  id            String   @id @default(cuid())
  date          DateTime @unique // Saturday date
  mainItems     String?  // 간식 메뉴
  specialItems  String?  // 매점 특식 판매
  imageUrl      String?  // Announcement image URL
  notice        String?  // 공지사항
  price         Float    @default(7.0)
  isPublished   Boolean  @default(false)
  deadline      DateTime?

  orders      Order[]
  couponSales CouponSale[]
}

model Order {
  id          String    @id @default(cuid())
  studentId   String?
  student     Student?  @relation(fields: [studentId], references: [id])
  menuId      String
  menu        Menu      @relation(fields: [menuId], references: [id])
  orderType   OrderType @default(PRE_ORDER)
  isPaid      Boolean   @default(false)
  amount      Float
  paymentDate DateTime?
  status      String    @default("WAITING") // WAITING, PAID, UNPAID, POST_PAID, CANCELLED
  isServed    Boolean   @default(false)
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([studentId, menuId])
}

model CouponSale {
  id            String   @id @default(cuid())
  studentId     String?
  student       Student?  @relation(fields: [studentId], references: [id])
  menuId        String
  menu          Menu     @relation(fields: [menuId], references: [id])
  quantity      Int      @default(1)
  amount        Float    @default(5.0) // $5 per coupon
  date          DateTime @default(now())
  paymentStatus String   @default("PAID") // PAID | UNPAID | POST_PAID

  @@unique([studentId, menuId])
}

model Post {
  id        String   @id @default(cuid())
  number    Int      @default(autoincrement())
  title     String
  content   String   @db.Text
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
